<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Icon-Set als StreamGeometry (24x24-Raster). Verwendung z. B.:
        <PathIcon Data="{StaticResource IconSelect}" Width="18" Height="18"/>
        Schlichte Line-Icons, einheitlicher Stil.
    -->

    <!-- Werkzeuge (gefüllte Silhouetten, da PathIcon füllt statt strokt) -->
    <StreamGeometry x:Key="IconSelect">M4 3 L4 17 L8 13 L11 19 L13 18 L10 12 L15 12 Z</StreamGeometry>
    <StreamGeometry x:Key="IconRectangle">M3 5 H21 V19 H3 Z M5 7 V17 H19 V7 Z</StreamGeometry>
    <StreamGeometry x:Key="IconEllipse">M12 5 A7 6 0 1 0 12.01 5 Z M12 7 A5 4 0 1 1 11.99 7 Z</StreamGeometry>
    <StreamGeometry x:Key="IconLine">M3.3 18.3 L18.3 3.3 L20.7 5.7 L5.7 20.7 Z</StreamGeometry>
    <StreamGeometry x:Key="IconPolyline">M2.4 16.2 L7 8 L13 13.6 L20.4 4.2 L21.6 5.8 L13 15.4 L7.4 10 L3.6 17 Z</StreamGeometry>
    <StreamGeometry x:Key="IconPolygon">M12 3 L21 9 L17.5 20 H6.5 L3 9 Z M12 6 L6 9.5 L8 17.5 H16 L18 9.5 Z</StreamGeometry>

    <!-- Anordnen: Ausrichten (Bezugskante als dünne Fläche + zwei Balken) -->
    <StreamGeometry x:Key="IconAlignLeft">M3 3 H5 V21 H3 Z M7 6 H18 V10 H7 Z M7 14 H13 V18 H7 Z</StreamGeometry>
    <StreamGeometry x:Key="IconAlignHCenter">M11 3 H13 V21 H11 Z M6.5 6 H17.5 V10 H6.5 Z M8.5 14 H15.5 V18 H8.5 Z</StreamGeometry>
    <StreamGeometry x:Key="IconAlignRight">M19 3 H21 V21 H19 Z M6 6 H17 V10 H6 Z M11 14 H17 V18 H11 Z</StreamGeometry>
    <StreamGeometry x:Key="IconAlignTop">M3 3 H21 V5 H3 Z M6 7 H10 V18 H6 Z M14 7 H18 V13 H14 Z</StreamGeometry>
    <StreamGeometry x:Key="IconAlignVCenter">M3 11 H21 V13 H3 Z M6 6.5 H10 V17.5 H6 Z M14 8.5 H18 V15.5 H14 Z</StreamGeometry>
    <StreamGeometry x:Key="IconAlignBottom">M3 19 H21 V21 H3 Z M6 6 H10 V17 H6 Z M14 11 H18 V17 H14 Z</StreamGeometry>
    <StreamGeometry x:Key="IconDistributeH">M3 3 H5 V21 H3 Z M19 3 H21 V21 H19 Z M9 8 H15 V16 H9 Z</StreamGeometry>
    <StreamGeometry x:Key="IconDistributeV">M3 3 H21 V5 H3 Z M3 19 H21 V21 H3 Z M8 9 H16 V15 H8 Z</StreamGeometry>

    <!-- Laser-Aktionen (gefüllte Silhouetten) -->
    <StreamGeometry x:Key="IconPlay">M7 4 L19 12 L7 20 Z</StreamGeometry>
    <StreamGeometry x:Key="IconPause">M7 4 H11 V20 H7 Z M13 4 H17 V20 H13 Z</StreamGeometry>
    <StreamGeometry x:Key="IconStop">M5 5 H19 V19 H5 Z</StreamGeometry>
    <!-- Pfeil zum Ursprung (oben links) -->
    <StreamGeometry x:Key="IconHome">M4 4 H13 V6.5 H8.2 L20 18.3 L18.3 20 L6.5 8.2 V13 H4 Z</StreamGeometry>
    <!-- Rahmen: vier Eckwinkel -->
    <StreamGeometry x:Key="IconFrame">M3 3 H10 V5 H5 V10 H3 Z M14 3 H21 V10 H19 V5 H14 Z M3 14 H5 V19 H10 V21 H3 Z M19 14 H21 V21 H14 V19 H19 Z</StreamGeometry>
    <StreamGeometry x:Key="IconRubberband">M12 3 L21 12 L12 21 L3 12 Z M12 7 L7 12 L12 17 L17 12 Z</StreamGeometry>
    <!-- Fadenkreuz mit Mittelpunkt -->
    <StreamGeometry x:Key="IconTarget">M11 3 H13 V7 H11 Z M11 17 H13 V21 H11 Z M3 11 H7 V13 H3 Z M17 11 H21 V13 H17 Z M12 10 A2 2 0 1 0 12.01 10 Z</StreamGeometry>

    <!-- Layer-/Panel-Utilities (gefüllt) -->
    <StreamGeometry x:Key="IconPlus">M11 5 H13 V11 H19 V13 H13 V19 H11 V13 H5 V11 H11 Z</StreamGeometry>
    <StreamGeometry x:Key="IconEye">M2 12 C5 6 19 6 22 12 C19 18 5 18 2 12 Z M12 9 A3 3 0 1 0 12.01 9 Z</StreamGeometry>
    <StreamGeometry x:Key="IconLock">M8 10 V7 A4 4 0 0 1 16 7 V10 H14 V7 A2 2 0 0 0 10 7 V10 Z M5 10 H19 V20 H5 Z</StreamGeometry>
</ResourceDictionary>
