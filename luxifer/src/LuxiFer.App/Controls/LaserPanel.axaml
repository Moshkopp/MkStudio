<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="720"
             x:Class="LuxiFer.App.Controls.LaserPanel">

    <UserControl.Styles>
        <!-- Sektions-Überschrift innerhalb des Panels -->
        <Style Selector="TextBlock.section">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="LetterSpacing" Value="1.4"/>
            <Setter Property="Margin" Value="2,0,0,8"/>
        </Style>

        <!-- Status-Karte: eigener, leicht vertiefter Block -->
        <Style Selector="Border.statuscard">
            <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
            <Setter Property="Padding" Value="12,11"/>
        </Style>

        <!-- Pill-Segmentumschalter (Job / Joggen) -->
        <Style Selector="Border.segwrap">
            <Setter Property="Background" Value="{StaticResource SurfaceInsetBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="9"/>
            <Setter Property="Padding" Value="3"/>
        </Style>

        <!-- Weicher Akzent-Schein unter der START-Kachel (Schatten nur auf Border möglich) -->
        <Style Selector="Border.primaryglow">
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
            <Setter Property="BoxShadow" Value="{StaticResource AccentGlow}"/>
        </Style>

        <!-- Primär-Aktion START: dominante, breite Kachel -->
        <Style Selector="Button.primary">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Background" Value="{StaticResource AccentTileBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.10"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.primary:pointerover">
            <Setter Property="Background" Value="{StaticResource AccentTileHoverBrush}"/>
        </Style>
        <Style Selector="Button.primary:pressed">
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>
        <Style Selector="Button.primary PathIcon">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Width" Value="20"/>
            <Setter Property="Height" Value="20"/>
        </Style>

        <!-- Pause / Stopp: ruhige Sekundär-Kacheln, farbige Semantik nur im Icon -->
        <Style Selector="Button.mini">
            <Setter Property="Height" Value="60"/>
            <Setter Property="Background" Value="{StaticResource SurfacePanelAltBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusMedium}"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.14"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.10"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.mini:pointerover">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        </Style>
        <Style Selector="Button.mini:pressed">
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>
        <Style Selector="Button.mini PathIcon">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
        </Style>
        <Style Selector="Button.mini.pause PathIcon">
            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
        </Style>
        <Style Selector="Button.mini.stop PathIcon">
            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
        </Style>

        <!-- Sekundäraktion (Ursprung / Rahmen / Gummiband): Icon links, Text, ganze Breite -->
        <Style Selector="Button.action">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}"/>
            <Setter Property="Padding" Value="11,0"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.action:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        </Style>
        <Style Selector="Button.action PathIcon">
            <Setter Property="Width" Value="17"/>
            <Setter Property="Height" Value="17"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        </Style>

        <!-- Jog-Steuerkreuz: quadratische Richtungstasten -->
        <Style Selector="Button.jog">
            <Setter Property="Background" Value="{StaticResource SurfacePanelAltBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}"/>
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.jog:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        </Style>

        <!-- Feiner Trenner zwischen Sektionen -->
        <Style Selector="Border.divider">
            <Setter Property="Height" Value="1"/>
            <Setter Property="Background" Value="{StaticResource BorderSubtleBrush}"/>
            <Setter Property="Margin" Value="0,4"/>
        </Style>
    </UserControl.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="16" Spacing="16">

            <!-- ===== Kopf: Titel ===== -->
            <TextBlock Text="LASER" Classes="h" Margin="0"/>

            <!-- ===== Status-Karte: Verbindung + Gerät ===== -->
            <Border Classes="statuscard">
                <StackPanel Spacing="11">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Right" Text="Getrennt"
                                   Classes="muted" FontWeight="Medium"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <!-- Status-Dot mit weichem Schein -->
                            <Border Width="10" Height="10" CornerRadius="5"
                                    Background="{StaticResource TextMutedBrush}"
                                    BoxShadow="0 0 8 0 #406A6E76"/>
                            <TextBlock Text="Verbindung" FontWeight="Medium"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </DockPanel>
                    <ComboBox HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem>Kein Gerät ausgewählt</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </Border>

            <!-- ===== Modus-Umschalter: Job / Joggen ===== -->
            <Border Classes="segwrap">
                <Grid ColumnDefinitions="*,*">
                    <ToggleButton Grid.Column="0" Classes="seg" Content="Job" IsChecked="True"/>
                    <ToggleButton Grid.Column="1" Classes="seg" Content="Joggen"/>
                </Grid>
            </Border>

            <!-- ===== Ausführung: dominante START-Aktion ===== -->
            <StackPanel Spacing="9">
                <TextBlock Text="AUSFÜHRUNG" Classes="section"/>
                <Border Classes="primaryglow">
                    <Button Classes="primary">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPlay}"/>
                            <TextBlock Text="START" FontSize="15" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Border>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="9">
                    <Button Grid.Column="0" Classes="mini pause">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconPause}"/>
                            <TextBlock Text="Pause" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Classes="mini stop">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconStop}"/>
                            <TextBlock Text="Stopp" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
                <CheckBox Content="Nur Auswahl lasern" Margin="0,2,0,0"/>
            </StackPanel>

            <Border Classes="divider"/>

            <!-- ===== Positionieren: Sekundäraktionen ===== -->
            <StackPanel Spacing="3">
                <TextBlock Text="POSITIONIEREN" Classes="section"/>
                <Button Classes="action">
                    <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource IconHome}"/>
                        <TextBlock Text="Zum Ursprung fahren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="action">
                    <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource IconFrame}"/>
                        <TextBlock Text="Rahmen abfahren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Classes="action">
                    <StackPanel Orientation="Horizontal" Spacing="11" VerticalAlignment="Center">
                        <PathIcon Data="{StaticResource IconRubberband}"/>
                        <TextBlock Text="Gummiband abfahren" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <Border Classes="divider"/>

            <!-- ===== Referenz setzen: Kopf / Ursprung ===== -->
            <StackPanel Spacing="9">
                <TextBlock Text="REFERENZ SETZEN" Classes="section"/>
                <Grid ColumnDefinitions="*,*" ColumnSpacing="9">
                    <Button Grid.Column="0" Classes="mini" Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconTarget}" Width="16" Height="16"
                                      Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="Kopf" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Grid.Column="1" Classes="mini" Height="40">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <PathIcon Data="{StaticResource IconTarget}" Width="16" Height="16"
                                      Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="Ursprung" FontWeight="Medium" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
                <StackPanel Spacing="6" Margin="0,4,0,0">
                    <TextBlock Text="Starten von" Classes="label"/>
                    <ComboBox HorizontalAlignment="Stretch" SelectedIndex="0">
                        <ComboBoxItem>Absolute Koordinaten</ComboBoxItem>
                        <ComboBoxItem>Aktuelle Position</ComboBoxItem>
                        <ComboBoxItem>Job-Nullpunkt</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>
