<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ctrl="using:LuxiFer.App.Controls"
             xmlns:canvas="using:LuxiFer.Core.Canvas"
             xmlns:vm="using:LuxiFer.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="240" d:DesignHeight="500"
             x:Class="LuxiFer.App.Controls.LayerPanel"
             x:DataType="vm:MainWindowViewModel">

    <UserControl.Styles>
        <Style Selector="ToggleButton.layericon">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="{StaticResource RadiusSmall}"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>
        <Style Selector="ToggleButton.layericon:checked">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="ToggleButton.layericon:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
        </Style>
    </UserControl.Styles>

    <DockPanel Margin="14">
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Button DockPanel.Dock="Right" Classes="icon" Command="{Binding AddLayerCommand}"
                    ToolTip.Tip="Layer hinzufügen">
                <PathIcon Data="{StaticResource IconPlus}" Width="16" Height="16"/>
            </Button>
            <TextBlock Text="SCHNITTE / EBENEN" Classes="h" VerticalAlignment="Center"/>
        </DockPanel>
        <ListBox ItemsSource="{Binding Layers}" SelectedItem="{Binding ActiveLayer}"
                 DoubleTapped="OnLayerDoubleTapped">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="canvas:Layer">
                    <DockPanel>
                        <!-- Farbchip (Anzeige der Ebenenfarbe; gesetzt über die
                             Farbpalette unten im Design-Modus). -->
                        <Border DockPanel.Dock="Left" Width="16" Height="16" CornerRadius="4"
                                VerticalAlignment="Center"
                                Background="{Binding ColorHex, Converter={x:Static ctrl:ToolConverters.HexToBrush}}"
                                BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1"/>

                        <!-- Sicht / Sperre rechts -->
                        <ToggleButton DockPanel.Dock="Right" Classes="layericon"
                                      IsChecked="{Binding Locked}"
                                      Click="OnLayerToggle" ToolTip.Tip="Sperre">
                            <PathIcon Data="{StaticResource IconLock}" Width="15" Height="15"/>
                        </ToggleButton>
                        <ToggleButton DockPanel.Dock="Right" Classes="layericon"
                                      IsChecked="{Binding Visible}"
                                      Click="OnLayerToggle" ToolTip.Tip="Sichtbar">
                            <PathIcon Data="{StaticResource IconEye}" Width="16" Height="16"/>
                        </ToggleButton>

                        <!-- Name + Parameterzeile (Modus · Speed · Power) -->
                        <StackPanel VerticalAlignment="Center" Margin="10,0,8,0" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontWeight="Medium"
                                       TextTrimming="CharacterEllipsis"/>
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <TextBlock Classes="muted" FontSize="11"
                                           Text="{Binding Mode, Converter={x:Static ctrl:ToolConverters.ModeLabel}}"/>
                                <TextBlock Classes="muted" FontSize="11" Text="·"/>
                                <TextBlock Classes="muted" FontSize="11"
                                           Text="{Binding SpeedMmS, StringFormat='{}{0:0} mm/s'}"/>
                            </StackPanel>
                        </StackPanel>
                    </DockPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</UserControl>
