<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:LuxiFer.App.ViewModels"
        xmlns:ctrl="using:LuxiFer.App.Controls"
        xmlns:canvas="using:LuxiFer.Core.Canvas"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="LuxiFer.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding Title}"
        Width="1280" Height="800"
        WindowState="Maximized">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel Background="{StaticResource SurfaceBaseBrush}">
        <!-- Menü -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_Datei">
                <MenuItem Header="_Neu" Command="{Binding NewProjectCommand}" InputGesture="Ctrl+N"/>
                <Separator/>
                <MenuItem Header="_Beenden" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Bearbeiten">
                <MenuItem Header="{Binding UndoHint}" Command="{Binding UndoActionCommand}"
                          InputGesture="Ctrl+Z"/>
                <MenuItem Header="{Binding RedoHint}" Command="{Binding RedoActionCommand}"
                          InputGesture="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="_Ansicht">
                <MenuItem Header="_Einpassen" Click="OnZoomToFitClick"/>
            </MenuItem>
        </Menu>

        <!-- Statusleiste -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfacePanelBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0"
                Padding="14,6">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Classes="muted" FontSize="12"
                           Text="{Binding CursorPosition}"/>
                <TextBlock Classes="muted" FontSize="12" Text="{Binding StatusText}"/>
            </DockPanel>
        </Border>

        <!-- Arbeitsbereich: Canvas + Lineale am Rand, Panele schweben über dem Canvas -->
        <Grid ColumnDefinitions="24,*" RowDefinitions="24,*">
            <!-- Eckfeld oben links -->
            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SurfacePanelBrush}"/>
            <!-- Horizontales Lineal oben -->
            <ctrl:RulerControl x:Name="RulerTop" Grid.Row="0" Grid.Column="1"
                               Orientation="Horizontal"/>
            <!-- Vertikales Lineal links -->
            <ctrl:RulerControl x:Name="RulerLeft" Grid.Row="1" Grid.Column="0"
                               Orientation="Vertical"/>

            <!-- Canvas + schwebende Panele liegen gemeinsam in der Canvas-Zelle,
                 damit die Panele innerhalb des Canvas bleiben und nicht in die
                 Lineale ragen. -->
            <Panel Grid.Row="1" Grid.Column="1">
                <ctrl:CanvasControl x:Name="Canvas"
                                    Document="{Binding Project.Canvas}"
                                    Tool="{Binding ActiveTool}"
                                    ActiveLayer="{Binding ActiveLayer}"
                                    UndoStack="{Binding Undo}"
                                    SelectedObject="{Binding SelectedObject, Mode=TwoWay}"/>

            <!-- Modus-Umschalter oben rechts (immer sichtbar) -->
            <Border Classes="floating" Padding="4" Margin="12"
                    HorizontalAlignment="Right" VerticalAlignment="Top">
                <Grid ColumnDefinitions="Auto,Auto">
                    <ToggleButton Grid.Column="0" Content="Design" Classes="mode" Width="90"
                                  IsChecked="{Binding IsDesignMode, Mode=OneWay}"
                                  Command="{Binding SetModeCommand}"
                                  CommandParameter="{x:Static vm:WorkMode.Design}"/>
                    <ToggleButton Grid.Column="1" Content="Laser" Classes="mode" Width="90"
                                  IsChecked="{Binding IsLaserMode, Mode=OneWay}"
                                  Command="{Binding SetModeCommand}"
                                  CommandParameter="{x:Static vm:WorkMode.Laser}"/>
                </Grid>
            </Border>

            <!-- DESIGN: Werkzeug-Palette links -->
            <Border Classes="floating" Padding="6" Margin="12"
                    HorizontalAlignment="Left" VerticalAlignment="Center"
                    IsVisible="{Binding IsDesignMode}">
                <StackPanel Spacing="4">
                    <ToggleButton Classes="tool" ToolTip.Tip="Auswählen (V)"
                                  IsChecked="{Binding ActiveTool, Converter={x:Static ctrl:ToolConverters.Equals}, ConverterParameter={x:Static ctrl:CanvasTool.Select}, Mode=OneWay}"
                                  Command="{Binding SelectToolCommand}"
                                  CommandParameter="{x:Static ctrl:CanvasTool.Select}">
                        <PathIcon Data="{StaticResource IconSelect}"/>
                    </ToggleButton>
                    <ToggleButton Classes="tool" ToolTip.Tip="Rechteck (R)"
                                  IsChecked="{Binding ActiveTool, Converter={x:Static ctrl:ToolConverters.Equals}, ConverterParameter={x:Static ctrl:CanvasTool.Rectangle}, Mode=OneWay}"
                                  Command="{Binding SelectToolCommand}"
                                  CommandParameter="{x:Static ctrl:CanvasTool.Rectangle}">
                        <PathIcon Data="{StaticResource IconRectangle}"/>
                    </ToggleButton>
                    <ToggleButton Classes="tool" ToolTip.Tip="Ellipse (E)"
                                  IsChecked="{Binding ActiveTool, Converter={x:Static ctrl:ToolConverters.Equals}, ConverterParameter={x:Static ctrl:CanvasTool.Ellipse}, Mode=OneWay}"
                                  Command="{Binding SelectToolCommand}"
                                  CommandParameter="{x:Static ctrl:CanvasTool.Ellipse}">
                        <PathIcon Data="{StaticResource IconEllipse}"/>
                    </ToggleButton>
                    <ToggleButton Classes="tool" ToolTip.Tip="Linie (L)"
                                  IsChecked="{Binding ActiveTool, Converter={x:Static ctrl:ToolConverters.Equals}, ConverterParameter={x:Static ctrl:CanvasTool.Line}, Mode=OneWay}"
                                  Command="{Binding SelectToolCommand}"
                                  CommandParameter="{x:Static ctrl:CanvasTool.Line}">
                        <PathIcon Data="{StaticResource IconLine}"/>
                    </ToggleButton>
                    <ToggleButton Classes="tool" ToolTip.Tip="Polyline (P)"
                                  IsChecked="{Binding ActiveTool, Converter={x:Static ctrl:ToolConverters.Equals}, ConverterParameter={x:Static ctrl:CanvasTool.Polyline}, Mode=OneWay}"
                                  Command="{Binding SelectToolCommand}"
                                  CommandParameter="{x:Static ctrl:CanvasTool.Polyline}">
                        <PathIcon Data="{StaticResource IconPolyline}"/>
                    </ToggleButton>
                    <ToggleButton Classes="tool" ToolTip.Tip="Polygon (G)"
                                  IsChecked="{Binding ActiveTool, Converter={x:Static ctrl:ToolConverters.Equals}, ConverterParameter={x:Static ctrl:CanvasTool.Polygon}, Mode=OneWay}"
                                  Command="{Binding SelectToolCommand}"
                                  CommandParameter="{x:Static ctrl:CanvasTool.Polygon}">
                        <PathIcon Data="{StaticResource IconPolygon}"/>
                    </ToggleButton>
                </StackPanel>
            </Border>

            <!-- DESIGN: Anordnen-Toolbar oben mittig -->
            <Border Classes="floating" Padding="5" Margin="0,16,0,0"
                    HorizontalAlignment="Center" VerticalAlignment="Top"
                    IsVisible="{Binding IsDesignMode}">
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="arrange" ToolTip.Tip="Links ausrichten"
                            Command="{Binding AlignLeftCommand}">
                        <PathIcon Data="{StaticResource IconAlignLeft}"/>
                    </Button>
                    <Button Classes="arrange" ToolTip.Tip="Horizontal zentrieren"
                            Command="{Binding AlignHCenterCommand}">
                        <PathIcon Data="{StaticResource IconAlignHCenter}"/>
                    </Button>
                    <Button Classes="arrange" ToolTip.Tip="Rechts ausrichten"
                            Command="{Binding AlignRightCommand}">
                        <PathIcon Data="{StaticResource IconAlignRight}"/>
                    </Button>
                    <Rectangle Width="1" Height="22" Fill="{StaticResource BorderStrongBrush}" Margin="5,0"/>
                    <Button Classes="arrange" ToolTip.Tip="Oben ausrichten"
                            Command="{Binding AlignTopCommand}">
                        <PathIcon Data="{StaticResource IconAlignTop}"/>
                    </Button>
                    <Button Classes="arrange" ToolTip.Tip="Vertikal zentrieren"
                            Command="{Binding AlignVCenterCommand}">
                        <PathIcon Data="{StaticResource IconAlignVCenter}"/>
                    </Button>
                    <Button Classes="arrange" ToolTip.Tip="Unten ausrichten"
                            Command="{Binding AlignBottomCommand}">
                        <PathIcon Data="{StaticResource IconAlignBottom}"/>
                    </Button>
                    <Rectangle Width="1" Height="22" Fill="{StaticResource BorderStrongBrush}" Margin="5,0"/>
                    <Button Classes="arrange" ToolTip.Tip="Horizontal verteilen"
                            Command="{Binding DistributeHCommand}">
                        <PathIcon Data="{StaticResource IconDistributeH}"/>
                    </Button>
                    <Button Classes="arrange" ToolTip.Tip="Vertikal verteilen"
                            Command="{Binding DistributeVCommand}">
                        <PathIcon Data="{StaticResource IconDistributeV}"/>
                    </Button>
                </StackPanel>
            </Border>

            <!-- DESIGN: Farbpalette unten mittig (färbt den aktiven Layer) -->
            <Border Classes="floating" Padding="8,6" Margin="0,0,0,16"
                    HorizontalAlignment="Center" VerticalAlignment="Bottom"
                    IsVisible="{Binding IsDesignMode}">
                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="Farbe" Classes="label" VerticalAlignment="Center"/>
                    <ItemsControl ItemsSource="{x:Static canvas:Layer.SwatchColors}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="6"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="x:String">
                                <Button Classes="swatchcircle"
                                        Background="{Binding Converter={x:Static ctrl:ToolConverters.HexToBrush}}"
                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).SetActiveColorCommand}"
                                        CommandParameter="{Binding}"
                                        ToolTip.Tip="{Binding}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- DESIGN: Layer-Panel + Auswahl rechts -->
            <Border Classes="floating" Width="240" Margin="12,64,12,12"
                    HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    IsVisible="{Binding IsDesignMode}">
                <DockPanel>
                    <!-- Transform-Palette unten angedockt -->
                    <StackPanel DockPanel.Dock="Bottom" Spacing="8" Margin="10">
                        <Rectangle Height="1" Fill="{StaticResource BorderSubtleBrush}"/>
                        <TextBlock Text="TRANSFORM" Classes="h"/>
                        <Grid ColumnDefinitions="72,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                              IsEnabled="{Binding HasSelection}">
                            <Grid.Styles>
                                <Style Selector="TextBox">
                                    <Setter Property="Margin" Value="0,2"/>
                                </Style>
                            </Grid.Styles>
                            <TextBlock Classes="label" Grid.Row="0" Grid.Column="0" Text="X mm"/>
                            <TextBox Grid.Row="0" Grid.Column="1" LostFocus="OnSelectionEditCommit"
                                     Text="{Binding SelX, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Classes="label" Grid.Row="1" Grid.Column="0" Text="Y mm"/>
                            <TextBox Grid.Row="1" Grid.Column="1" LostFocus="OnSelectionEditCommit"
                                     Text="{Binding SelY, UpdateSourceTrigger=LostFocus}"/>
                            <!-- Breite/Höhe/Skalierung/Drehung nur bei Einzelauswahl -->
                            <TextBlock Classes="label" Grid.Row="2" Grid.Column="0" Text="Breite mm"/>
                            <TextBox Grid.Row="2" Grid.Column="1" LostFocus="OnSelectionEditCommit"
                                     IsEnabled="{Binding IsSingleSelection}"
                                     Text="{Binding SelWidth, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Classes="label" Grid.Row="3" Grid.Column="0" Text="Höhe mm"/>
                            <TextBox Grid.Row="3" Grid.Column="1" LostFocus="OnSelectionEditCommit"
                                     IsEnabled="{Binding IsSingleSelection}"
                                     Text="{Binding SelHeight, UpdateSourceTrigger=LostFocus}"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" Margin="0,2"
                                      Content="Seitenverhältnis sperren"
                                      IsEnabled="{Binding IsSingleSelection}"
                                      IsChecked="{Binding LockAspect}"/>
                            <TextBlock Classes="label" Grid.Row="5" Grid.Column="0" Text="Skalierung %"/>
                            <TextBox Grid.Row="5" Grid.Column="1" LostFocus="OnSelectionEditCommit"
                                     IsEnabled="{Binding IsSingleSelection}"
                                     Text="{Binding SelScalePct, UpdateSourceTrigger=LostFocus}"/>
                            <TextBlock Classes="label" Grid.Row="6" Grid.Column="0" Text="Drehung °"/>
                            <TextBox Grid.Row="6" Grid.Column="1" LostFocus="OnSelectionEditCommit"
                                     IsEnabled="{Binding IsSingleSelection}"
                                     Text="{Binding SelRotation, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>
                        <TextBlock Text="Kein Objekt ausgewählt" Classes="muted"
                                   IsVisible="{Binding ShowNoSelectionHint}"/>
                    </StackPanel>
                    <ctrl:LayerPanel x:Name="LayerPanelRight" DataContext="{Binding}"/>
                </DockPanel>
            </Border>

            <!-- LASER: Layer-Panel links -->
            <Border Classes="floating" Width="240" Margin="12"
                    HorizontalAlignment="Left" VerticalAlignment="Stretch"
                    IsVisible="{Binding IsLaserMode}">
                <ctrl:LayerPanel x:Name="LayerPanelLeft" DataContext="{Binding}"/>
            </Border>

            <!-- LASER: Maschinen-Steuerpanel rechts -->
            <Border Classes="floating" Width="300" Margin="12,64,12,12"
                    HorizontalAlignment="Right" VerticalAlignment="Stretch"
                    IsVisible="{Binding IsLaserMode}">
                <ctrl:LaserPanel Margin="10"/>
            </Border>
            </Panel>
        </Grid>
    </DockPanel>
</Window>
