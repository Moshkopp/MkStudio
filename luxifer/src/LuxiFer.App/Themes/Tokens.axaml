<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Zentrale Design-Tokens für LuxiFer. Ein dunkles, ruhiges Farbsystem mit
        einer Akzentfarbe. Alle Panele/Controls beziehen sich auf diese Werte,
        damit die Oberfläche als ein System wirkt.
    -->

    <!-- Flächen (Figma/Affinity: warm-neutrale Graustufen, feine Stufung) -->
    <Color x:Key="SurfaceBase">#141518</Color>      <!-- Fenster-/Canvas-Hintergrund -->
    <Color x:Key="SurfacePanel">#1C1E22</Color>     <!-- Panele -->
    <Color x:Key="SurfacePanelHi">#232529</Color>   <!-- Panel-Oberkante (Verlauf) -->
    <Color x:Key="SurfacePanelAlt">#26282D</Color>  <!-- Eingaben, Zeilen -->
    <Color x:Key="SurfaceHover">#2E3036</Color>
    <Color x:Key="SurfaceActive">#363940</Color>

    <!-- Linien / Trenner -->
    <Color x:Key="BorderSubtle">#2A2D33</Color>
    <Color x:Key="BorderStrong">#3A3E45</Color>

    <!-- Text -->
    <Color x:Key="TextPrimary">#EDEEF0</Color>
    <Color x:Key="TextSecondary">#A2A6AD</Color>
    <Color x:Key="TextMuted">#6A6E76</Color>

    <!-- Akzent (eine Farbe, konsequent) -->
    <Color x:Key="Accent">#4C82F7</Color>
    <Color x:Key="AccentHover">#5F92FF</Color>
    <Color x:Key="AccentMuted">#2A3B5C</Color>

    <!-- Statusfarben (nur für Aktionen mit klarer Semantik) -->
    <Color x:Key="Success">#3FB27F</Color>
    <Color x:Key="Warning">#E0A83B</Color>
    <Color x:Key="Danger">#E5645D</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="SurfaceBaseBrush" Color="{StaticResource SurfaceBase}"/>
    <SolidColorBrush x:Key="SurfacePanelBrush" Color="{StaticResource SurfacePanel}"/>
    <SolidColorBrush x:Key="SurfacePanelAltBrush" Color="{StaticResource SurfacePanelAlt}"/>
    <SolidColorBrush x:Key="SurfaceHoverBrush" Color="{StaticResource SurfaceHover}"/>
    <SolidColorBrush x:Key="SurfaceActiveBrush" Color="{StaticResource SurfaceActive}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHover}"/>
    <SolidColorBrush x:Key="AccentMutedBrush" Color="{StaticResource AccentMuted}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}"/>

    <!-- Panel-Verlauf: oben minimal heller, gibt schwebenden Panelen Tiefe -->
    <LinearGradientBrush x:Key="PanelGradientBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Offset="0" Color="{StaticResource SurfacePanelHi}"/>
        <GradientStop Offset="1" Color="{StaticResource SurfacePanel}"/>
    </LinearGradientBrush>

    <!-- Feiner Innen-Highlight-Rand (Glaskante oben) -->
    <SolidColorBrush x:Key="PanelBorderBrush" Color="#33FFFFFF"/>

    <!-- Eingebettete Karte (leicht vertiefter Bereich innerhalb eines Panels) -->
    <SolidColorBrush x:Key="SurfaceInsetBrush" Color="#16171B"/>

    <!-- Primär-Kachel: Akzent-Verlauf für die dominante Aktion (START) -->
    <LinearGradientBrush x:Key="AccentTileBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Offset="0" Color="#5A8CFF"/>
        <GradientStop Offset="1" Color="#3F72E6"/>
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="AccentTileHoverBrush" StartPoint="0%,0%" EndPoint="0%,100%">
        <GradientStop Offset="0" Color="#6D9BFF"/>
        <GradientStop Offset="1" Color="#4C82F7"/>
    </LinearGradientBrush>

    <!-- Weicher Akzent-Schein unter der Primär-Aktion -->
    <BoxShadows x:Key="AccentGlow">0 4 16 -2 #664C82F7</BoxShadows>

    <!-- Radien -->
    <CornerRadius x:Key="RadiusSmall">6</CornerRadius>
    <CornerRadius x:Key="RadiusMedium">10</CornerRadius>
    <CornerRadius x:Key="RadiusLarge">14</CornerRadius>

    <!-- Gestaffelte Schatten (weicher, tiefer – wie schwebende Ebenen) -->
    <BoxShadows x:Key="PanelShadow">0 2 6 0 #40000000, 0 12 40 -4 #70000000</BoxShadows>
</ResourceDictionary>
